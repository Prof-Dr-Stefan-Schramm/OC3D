cff-version: 1.2.0
message: "If you use OC3D in teaching or research, please cite it as below."
type: software
title: "OC3D — Organic Chemistry in Interactive 3D: An Open-Source, Browser-Based 3D Learning Environment for Reaction Mechanisms, Conformational Analysis, and Stereochemistry in Introductory Organic Chemistry"
authors:
  - family-names: "Schramm"
    given-names: "Stefan"
    affiliation: "HTW Dresden — University of Applied Sciences, Dresden, Germany"
    orcid: "https://orcid.org/0000-0002-6109-0893"
version: "1.0.0"
date-released: "2026-07-05"
license: MIT
